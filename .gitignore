# Visual Studio 2015 user specific files
.vs/

# Compiled Object files
*.slo
*.lo
*.o
*.obj

# Precompiled Headers
*.gch
*.pch

# Compiled Dynamic libraries
*.so
*.dylib
*.dll

# Fortran module files
*.mod

# Compiled Static libraries
*.lai
*.la
*.a
*.lib

# Executables
*.exe
*.out
*.app
*.ipa

# These project files can be generated by the engine
*.xcodeproj
*.xcworkspace
*.sln
*.suo
*.opensdf
*.sdf
*.VC.db
*.VC.opendb
.vsconfig

# Precompiled Assets
Doce_Minuticos/SourceArt/**/*.png
Doce_Minuticos/SourceArt/**/*.tga

# Binary Files
Doce_Minuticos/Binaries/*
Doce_Minuticos/Plugins/**/Binaries/*

# Builds
Doce_Minuticos/Build/*

# Whitelist PakBlacklist-<BuildConfiguration>.txt files
!Doce_Minuticos/Build/*/
Doce_Minuticos/Build/*/**
!Doce_Minuticos/Build/*/PakBlacklist*.txt

# Don't ignore icon files in Build
!Doce_Minuticos/Build/**/*.ico

# Built data for maps
Doce_Minuticos/*_BuiltData.uasset

# Configuration files generated by the Editor
Doce_Minuticos/Saved/*

# Compiled source files for the engine to use
Doce_Minuticos/Intermediate/*
Doce_Minuticos/Plugins/**/Intermediate/*

# Cache files for the editor to use
Doce_Minuticos/DerivedDataCache/*

# Unreal autosaves
Doce_Minuticos/Saved/Autosaves/

# Crash logs
Doce_Minuticos/Saved/Crashes/

# Logs
Doce_Minuticos/Saved/Logs/

# Rider / JetBrains
.idea/

# VSCode
.vscode/

# Mac
.DS_Store
Doce_Minuticos/Saved/Logs/